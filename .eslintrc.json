{
  "env": { "node": true, "es2022": true },
  "parserOptions": { "ecmaVersion": 2022, "sourceType": "module" },
  "rules": {
    "no-unused-vars": "warn",
    "no-undef": "error",
    "no-dupe-keys": "error",
    "no-duplicate-case": "error",
    "no-empty": "warn",
    "no-console": "off",
    "no-constant-condition": "warn",
    "no-redeclare": "error",
    "no-shadow": "warn",
    "eqeqeq": "warn",
    "curly": "warn",
    "no-throw-literal": "error"
  }
}
